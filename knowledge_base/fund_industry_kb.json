{
  "version": "1.0.0",
  "description": "公募基金行业通用知识库",
  "categories": {
    "fund_types": {
      "description": "基金类型",
      "items": [
        {
          "term": "开放式基金",
          "definition": "基金份额不固定，总规模随申购赎回变动",
          "features": ["高流动性", "按净值申赎", "T+1确认"],
          "prd_points": ["交易时间", "巨额赎回处理", "净值披露时间"]
        },
        {
          "term": "封闭式基金",
          "definition": "存续期内份额固定，在交易所上市交易",
          "features": ["份额固定", "二级市场交易", "存在折溢价"],
          "prd_points": ["上市交易规则", "封闭期管理", "到期转型"]
        },
        {
          "term": "ETF",
          "definition": "交易型开放式指数基金，采用被动管理",
          "features": ["实物申赎", "实时交易", "每15秒披露IOPV"],
          "prd_points": ["申购赎回清单(PCF)", "现金替代机制", "套利机制"]
        },
        {
          "term": "LOF",
          "definition": "上市型开放式基金，支持场内外交易",
          "features": ["双重交易渠道", "跨系统转托管", "每日披露净值"],
          "prd_points": ["转托管流程", "套利机制", "场内外价格同步"]
        },
        {
          "term": "货币基金",
          "definition": "投资于货币市场工具的基金",
          "features": ["T+0快速赎回", "净值保持1元", "收益按日结转"],
          "prd_points": ["快赎额度管理", "收益分配", "流动性管理"]
        }
      ]
    },
    "core_systems": {
      "description": "核心系统",
      "items": [
        {
          "term": "TA系统",
          "full_name": "Transfer Agent / 注册登记系统",
          "definition": "处理基金申赎端业务，管理投资者基金份额登记",
          "types": ["中登TA", "自建TA", "中登分TA"],
          "core_functions": [
            "投资者账户开户/销户/变更",
            "基金份额登记与过户",
            "申购/赎回/转换交易确认",
            "分红权益登记与发放",
            "非交易过户"
          ],
          "prd_points": [
            "账户体系设计",
            "份额过户规则",
            "确认时效",
            "数据同步机制"
          ]
        },
        {
          "term": "FA系统",
          "full_name": "Fund Accounting / 估值核算系统",
          "definition": "负责每日计算基金资产净值(NAV)",
          "core_functions": [
            "资产估值(股票/债券/现金等)",
            "净值计算(NAV)",
            "会计核算与报表生成",
            "费用计提(管理费/托管费)"
          ],
          "prd_points": [
            "估值方法选择",
            "估值精度规则",
            "异常处理机制",
            "对账流程"
          ]
        },
        {
          "term": "投资交易系统",
          "definition": "基金经理进行投资交易的系统(如O32/O45)",
          "core_functions": [
            "指令管理",
            "交易执行",
            "成交回报",
            "风控合规"
          ],
          "prd_points": [
            "与估值系统对接",
            "交易数据传输",
            "资金头寸管理"
          ]
        }
      ]
    },
    "business_terms": {
      "description": "业务术语",
      "items": [
        {
          "term": "NAV",
          "full_name": "Net Asset Value",
          "definition": "基金资产净值，每份基金的价值",
          "formula": "NAV = (基金资产总值 - 基金负债总值) / 基金总份额",
          "prd_points": ["计算精度(通常4位小数)", "披露时间", "四舍五入规则"]
        },
        {
          "term": "申赎",
          "full_name": "Subscription / Redemption",
          "definition": "基金申购与赎回",
          "prd_points": [
            "交易时间(通常9:30-15:00)",
            "确认时效(T+1或T+2)",
            "巨额赎回处理"
          ]
        },
        {
          "term": "巨额赎回",
          "definition": "单日净赎回超过基金总份额10%",
          "handling": ["延期办理", "部分确认", "取消赎回"],
          "prd_points": ["触发条件", "处理流程", "信息披露"]
        },
        {
          "term": "T日",
          "definition": "交易日",
          "related": ["T+1确认日", "T+n资金到账日"],
          "prd_points": ["交易截止时间(通常15:00)", "节假日处理"]
        },
        {
          "term": "分红方式",
          "options": ["现金分红", "红利再投资"],
          "prd_points": ["默认设置", "修改时效", "权益登记日"]
        },
        {
          "term": "非交易过户",
          "scenarios": ["继承", "赠予", "司法扣划"],
          "prd_points": ["业务场景", "审核流程", "税费处理"]
        }
      ]
    },
    "process_flows": {
      "description": "业务流程",
      "items": [
        {
          "name": "基金开户流程",
          "steps": [
            "实名认证(公安联网核查)",
            "风险测评",
            "适当性匹配",
            "合格投资者认定(如适用)",
            "生成TA账号"
          ]
        },
        {
          "name": "申购流程",
          "steps": [
            "T日提交申购申请",
            "资金冻结/扣款",
            "T+1日份额确认",
            "T+2日资金清算"
          ]
        },
        {
          "name": "赎回流程",
          "steps": [
            "T日提交赎回申请",
            "T+1日确认赎回份额",
            "计算赎回金额(按T日净值)",
            "资金到账(T+n)"
          ]
        },
        {
          "name": "估值核算流程",
          "steps": [
            "获取市场行情数据",
            "获取交易成交数据",
            "获取份额变动数据",
            "计算各项资产公允价值",
            "计提应收应付费用",
            "计算基金资产净值/份额净值",
            "生成估值表与会计凭证",
            "净值披露与数据分发"
          ]
        }
      ]
    },
    "precision_rules": {
      "description": "精度规则",
      "items": [
        {"type": "金额", "precision": 2, "rounding": "四舍五入"},
        {"type": "份额", "precision": 2, "note": "货币基金保留4位"},
        {"type": "净值", "precision": 4, "rounding": "四舍五入"},
        {"type": "费率", "precision": 4, "note": "计算时采用精确费率"}
      ]
    },
    "compliance": {
      "description": "合规要求",
      "items": [
        "适当性管理：投资者风险承受能力与产品风险等级匹配",
        "反洗钱(AML)：客户身份识别要求",
        "信息披露：净值披露、定期报告、临时报告",
        "监管报送：证监会、基金业协会、中国结算等"
      ]
    }
  }
}
